# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fitness_agent

# ============================================================
# DeepSeek (聊天 + VL2 视觉 + Function Calling)
# 注册地址: https://platform.deepseek.com
# 同一个 API Key 覆盖: 对话模型 / VL2 图片理解 / Tool Calling
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 对话模型 (可在 ChatPanel 切换)
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_VL2_MODEL=deepseek-vl2

# ============================================================
# 百度AI 菜品识别 (食物图片 → 菜名 + 热量估算)
# 注册地址: https://console.bce.baidu.com/ai/#/ai/imagerecognition/overview
# 免费额度: 3000次/月
# 创建应用 → 选择"图像识别" → 获取 AppID / API Key / Secret Key
# ============================================================
BAIDU_AI_APP_ID=your_baidu_app_id_here
BAIDU_AI_API_KEY=your_baidu_api_key_here
BAIDU_AI_SECRET_KEY=your_baidu_secret_key_here

# ============================================================
# 天聚数行 食物营养API (菜名 → 详细营养素)
# 注册地址: https://www.tianapi.com/apiview/92
# 约 0.01元/次, 覆盖 2000+ 食物, 30+ 营养参数
# ============================================================
TIANAPI_KEY=your_tianapi_key_here

# ============================================================
# Volcengine OCR (InBody 体测报告识别)
# ============================================================
VOLCENGINE_ACCESS_KEY_ID=your_access_key_id_here
VOLCENGINE_SECRET_ACCESS_KEY=your_secret_access_key_here
VOLCENGINE_REGION=cn-beijing
VOLCENGINE_SERVICE=cv
VOLCENGINE_OCR_HOST=visual.volcengineapi.com
VOLCENGINE_OCR_ACTION=OCRNormal
VOLCENGINE_OCR_VERSION=2020-08-26
VOLCENGINE_OCR_IMAGE_FIELD=ImageBase64
