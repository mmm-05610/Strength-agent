# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fitness_agent

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Volcengine OCR (InBody image)
# NOTE: Secret key may already be base64-encoded; the client will try to auto-decode when it looks like base64.
VOLCENGINE_ACCESS_KEY_ID=your_access_key_id_here
VOLCENGINE_SECRET_ACCESS_KEY=your_secret_access_key_here
VOLCENGINE_REGION=cn-beijing
VOLCENGINE_SERVICE=cv
VOLCENGINE_OCR_HOST=visual.volcengineapi.com
VOLCENGINE_OCR_ACTION=OCRNormal
VOLCENGINE_OCR_VERSION=2020-08-26
VOLCENGINE_OCR_IMAGE_FIELD=ImageBase64
